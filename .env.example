# Environment variables for Clara Pipeline
# Copy this to .env and fill in values

# n8n Configuration
N8N_BASIC_AUTH_USER=clara
N8N_BASIC_AUTH_PASSWORD=clara2026
GENERIC_TIMEZONE=America/New_York

# Retell Configuration (if free API access available)
# RETELL_API_KEY=your_key_here

# Dashboard
FLASK_ENV=development
FLASK_DEBUG=1
DASHBOARD_PORT=5000

# Pipeline
LOG_LEVEL=INFO
