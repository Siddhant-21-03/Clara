{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Account Memo",
  "description": "Structured account configuration extracted from demo/onboarding calls for Clara Answers AI voice agent",
  "type": "object",
  "required": ["account_id", "company_name", "version", "source", "created_at"],
  "properties": {
    "account_id": {
      "type": "string",
      "description": "Unique identifier for the account (e.g., ACC-001)"
    },
    "company_name": {
      "type": "string",
      "description": "Name of the client company"
    },
    "version": {
      "type": "string",
      "enum": ["v1", "v2"],
      "description": "v1 = demo-derived, v2 = onboarding-confirmed"
    },
    "source": {
      "type": "string",
      "enum": ["demo_call", "onboarding_call", "onboarding_form"],
      "description": "Source of the data"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "business_hours": {
      "type": "object",
      "properties": {
        "days": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
          }
        },
        "start": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$",
          "description": "Start time in HH:MM format"
        },
        "end": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$",
          "description": "End time in HH:MM format"
        },
        "timezone": {
          "type": "string",
          "description": "IANA timezone (e.g., America/New_York)"
        }
      }
    },
    "office_address": {
      "type": ["string", "null"],
      "description": "Office address if provided, null if unknown"
    },
    "services_supported": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of services the company offers"
    },
    "emergency_definition": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of triggers that constitute an emergency"
    },
    "emergency_routing_rules": {
      "type": "object",
      "properties": {
        "primary_contact": {
          "type": "object",
          "properties": {
            "name": { "type": ["string", "null"] },
            "phone": { "type": ["string", "null"] },
            "role": { "type": ["string", "null"] }
          }
        },
        "secondary_contact": {
          "type": "object",
          "properties": {
            "name": { "type": ["string", "null"] },
            "phone": { "type": ["string", "null"] },
            "role": { "type": ["string", "null"] }
          }
        },
        "fallback": {
          "type": ["string", "null"],
          "description": "What to do if all contacts fail"
        },
        "transfer_timeout_seconds": {
          "type": ["integer", "null"],
          "description": "Max seconds to wait for transfer before fallback"
        }
      }
    },
    "non_emergency_routing_rules": {
      "type": "object",
      "properties": {
        "during_hours": {
          "type": ["string", "null"],
          "description": "Routing during business hours for non-emergency"
        },
        "after_hours": {
          "type": ["string", "null"],
          "description": "Routing after hours for non-emergency"
        }
      }
    },
    "call_transfer_rules": {
      "type": "object",
      "properties": {
        "timeout_seconds": {
          "type": ["integer", "null"]
        },
        "max_retries": {
          "type": ["integer", "null"]
        },
        "failure_message": {
          "type": ["string", "null"]
        }
      }
    },
    "integration_constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Rules about ServiceTrade or other system integrations"
    },
    "after_hours_flow_summary": {
      "type": ["string", "null"],
      "description": "Summary of after-hours call handling"
    },
    "office_hours_flow_summary": {
      "type": ["string", "null"],
      "description": "Summary of business-hours call handling"
    },
    "questions_or_unknowns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Details that are missing or need clarification"
    },
    "notes": {
      "type": ["string", "null"],
      "description": "Any additional notes"
    }
  }
}
